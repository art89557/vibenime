# VibeNime Environment Variables
# Copy file ini menjadi .env lalu isi sesuai akun Anda.

# AniList OAuth client ID (angka)
# Lihat docs/SETUP_ANILIST.md
ANILIST_CLIENT_ID=12345

# Sample HLS stream URL untuk player demo.
# Default: Mux test stream (Big Buck Bunny multi-bitrate, support quality switcher).
# Boleh diganti ke sample lain (Apple BipBop, Sintel, dll) kalau mau.
SAMPLE_STREAM_URL=https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8
