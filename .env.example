# VibeNime Environment Variables
# Copy file ini menjadi .env lalu isi sesuai akun Anda.

# Sample HLS stream URL untuk player demo (fallback default).
# Default: Mux test stream (Big Buck Bunny multi-bitrate, support quality switcher).
SAMPLE_STREAM_URL=https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8

# Supabase (database video catalog)
# Lihat docs/SETUP_SUPABASE.md
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Sentry crash reporting (opsional). Daftar di sentry.io,
# buat project Flutter, copy DSN ke sini. Kalau kosong, app tetap jalan
# cuma tanpa crash reporting.
SENTRY_DSN=

# Consumet API self-hosted base URL — untuk scraping source Indonesia
# (Otakudesu / Kuramanime / Samehadaku) via fork Consumet API yang sudah
# include 3 modul Indo. Kalau kosong, fallback ke public Consumet mirror
# (gogoanime) + Mux sample stream.
# Deploy step: lihat plan/ATAU docs/SETUP_CONSUMET.md
CONSUMET_API_URL=

# Sumber streaming sub Indonesia (Samehadaku/Otakudesu) via API REST.
# KOSONGKAN untuk pakai default hosted gratis: Sanka Vollerei
# (https://www.sankavollerei.web.id/anime) — tanpa self-host, langsung jalan.
# Isi hanya kalau mau override (mis. self-host wajik-anime-api). Base URL TANPA
# trailing slash; path otomatis /{source}/... (mis. /samehadaku/search).
ANIME_API_URL=

# aniwatch-api (sub English) — sumber streaming English UTAMA. Pembungkus
# HiAnime (github.com/ghoshRitesh12/aniwatch-api) yang balas M3U8 + subtitle
# .vtt + intro/outro. WAJIB self-host (tak ada demo publik andal):
#   docker run -d -p 4000:4000 ghcr.io/ghoshritesh12/aniwatch
# atau deploy 1-klik ke Render/Railway. Isi base URL TANPA trailing slash
# (mis. https://my-aniwatch.onrender.com); path otomatis /api/v2/hianime/...
# Kosong = source Aniwatch di-skip.
ANIWATCH_API_URL=

# Miruro-API (sub English) — sumber streaming English FALLBACK (M3U8 + intro/
# outro, by AniList ID). Self-host Python/FastAPI. Kosong = di-skip.
MIRURO_API_URL=
# (Opsional) API key kalau deploy Miruro di-lock dengan env API_KEY.
MIRURO_API_KEY=

# Sankanime (sub Indonesia) — template URL halaman tonton yang di-embed via
# WebView. Sankanime SPA (Cloudflare, tanpa API publik), jadi app cuma membangun
# URL embed dari template ini. Placeholder: {slug} (judul→kebab-case),
# {title} (judul URL-encoded), {ep} (nomor episode).
# Contoh: https://sankanime.web.id/{slug}-episode-{ep}-sub-indo
# Kosong = source Sankanime di-skip.
SANKANIME_EMBED_TEMPLATE=
